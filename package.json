    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-tsparticles": "^2.12.2",
    "three": "^0.185.0",
    "tsparticles-engine": "^2.12.0",
    "tsparticles-slim": "^2.12.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "react-snap": "^1.23.0",
    "vite": "^8.1.0"
  }
